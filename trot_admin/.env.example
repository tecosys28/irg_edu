# Copy this file to .env and fill in every value before running.

# Django core
DJANGO_SECRET_KEY=change-me-to-a-long-random-string-at-least-50-chars
DJANGO_DEBUG=True
# Comma-separated allowed hosts (use * only in dev)
DJANGO_ALLOWED_HOSTS=*

# Firebase — path to your service account JSON key
# Download from: Firebase Console > Project Settings > Service Accounts > Generate new private key
GOOGLE_APPLICATION_CREDENTIALS=serviceAccountKey.json

# Admin panel login credentials
# Run:  python manage.py create_admin   to apply these.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123
