rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Super admin — full access to everything
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'tidkejp@gmail.com';
    }

    // Users: owner can read/write own profile; admin can read/write all
    match /users/{userId} {
      allow read, write: if isAdmin()
        || (request.auth != null && request.auth.uid == userId);
    }

    // Issuances: institutes manage their own; admin can do everything
    match /issuances/{issuanceId} {
      allow read, write: if isAdmin();
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.instituteId == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.instituteId == request.auth.uid;
    }

    // Holdings: owner or admin
    match /holdings/{holdingId} {
      allow read, write: if isAdmin();
      allow read, write: if request.auth != null
        && resource.data.ownerId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid;
    }

    // Sponsorships: sponsors/students or admin
    match /sponsorships/{sponsorshipId} {
      allow read, write: if isAdmin();
      allow read: if request.auth != null
        && (resource.data.sponsorId == request.auth.uid
            || resource.data.studentId == request.auth.uid);
      allow create: if request.auth != null
        && request.resource.data.sponsorId == request.auth.uid;
    }
  }
}
