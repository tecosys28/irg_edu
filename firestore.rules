rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Super admin — full access to everything
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'tidkejp@gmail.com';
    }

    // Users: owner can read/write own profile; admin can read/write all
    match /users/{userId} {
      allow read, write: if isAdmin()
        || (request.auth != null && request.auth.uid == userId);
    }

    // Issuances: institutes manage their own; admin can do everything; all authenticated users can read
    match /issuances/{issuanceId} {
      allow read, write: if isAdmin();
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.instituteId == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.instituteId == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.instituteId == request.auth.uid;
    }

    // Holdings: owner or admin; create allowed for authenticated users (purchase/swap writes)
    match /holdings/{holdingId} {
      allow read, write: if isAdmin();
      allow read: if request.auth != null
        && resource.data.ownerId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.ownerId == request.auth.uid;
    }

    // Sponsorships: sponsors/students or admin
    match /sponsorships/{sponsorshipId} {
      allow read, write: if isAdmin();
      allow read: if request.auth != null
        && (resource.data.sponsorId == request.auth.uid
            || resource.data.studentId == request.auth.uid);
      allow create: if request.auth != null
        && request.resource.data.sponsorId == request.auth.uid;
    }

    // Redemptions: owner or admin
    match /redemptions/{redemptionId} {
      allow read, write: if isAdmin();
      allow read: if request.auth != null
        && resource.data.ownerId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid;
    }

    // Swaps: owner or admin
    match /swaps/{swapId} {
      allow read, write: if isAdmin();
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
    }

    // Minting Programs: minter owns, consultants can read all submitted, admin full access
    match /mintingPrograms/{programId} {
      allow read, write: if isAdmin();
      allow read: if request.auth != null;   // consultants need to read all submitted
      allow create: if request.auth != null
        && request.resource.data.minterId == request.auth.uid;
      allow update: if request.auth != null
        && (resource.data.minterId == request.auth.uid
            || request.auth != null);        // consultants can update reviews/status
    }
  }
}
